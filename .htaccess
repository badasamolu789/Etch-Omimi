# Enable URL rewriting for clean extensionless routes.
RewriteEngine On
RewriteBase /

# Redirect direct .html requests to the clean extensionless URL.
RewriteCond %{THE_REQUEST} \s/([^.]+?)\.html[?\s] [NC]
RewriteRule ^ %1 [R=301,L]

# Serve existing files and directories normally.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# If an extensionless URL matches an existing .html file, rewrite internally.
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]

# Optional: force a trailing slash on directory paths for better cleanliness.
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^(.+[^/])$ %{REQUEST_URI}/ [R=301,L]
